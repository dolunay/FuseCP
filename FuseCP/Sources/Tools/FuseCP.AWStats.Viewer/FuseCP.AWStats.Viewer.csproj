<Project Sdk="Microsoft.NET.Sdk.Web">
    <PropertyGroup>
        <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
        <TargetFramework>net10.0-windows</TargetFramework>
        <OutputPath>bin\</OutputPath>
        <LangVersion>13</LangVersion>
        <Nullable>disable</Nullable>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.0" />
    </ItemGroup>
    <ItemGroup>
        <Compile Include="..\..\VersionInfo.cs" Link="VersionInfo.cs" />
        <Compile Remove="Default.aspx.cs" />
        <Compile Remove="Default.aspx.designer.cs" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\..\FuseCP.EnterpriseServer.Base\FuseCP.EnterpriseServer.Base.csproj" />
        <ProjectReference Include="..\..\FuseCP.EnterpriseServer\WebServices\FuseCP.Build\FuseCP.EnterpriseServer.Client.csproj" />
        <ProjectReference Include="..\..\FuseCP.Providers.Base\FuseCP.Providers.Base.csproj" />
        <ProjectReference Include="..\..\FuseCP.Web.Clients\FuseCP.Web.Clients.csproj" />
    </ItemGroup>
</Project>
