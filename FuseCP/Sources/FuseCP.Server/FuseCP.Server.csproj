<Project Sdk="Microsoft.NET.Sdk.Web">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>disable</Nullable>
        <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
        <CompilerGeneratedFilesOutputPath>WebServices</CompilerGeneratedFilesOutputPath>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <LangVersion>13</LangVersion>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
        <IntermediateOutputPath>$(BaseIntermediateOutputPath)$(Configuration)\$(TargetFramework.ToLowerInvariant())\</IntermediateOutputPath>
        <UserSecretsId>f2178b6b-fdfa-4b50-ba11-779a6fcd69f3</UserSecretsId>
    </PropertyGroup>

    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0'">
        <OutputPath>bin_dotnet</OutputPath>
        <StartupObject>FuseCP.Server.Program</StartupObject>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
        <Compile Remove="WebServices\**\*.*" />
        <Content Remove="WebServices\**\*.*" />
        <EmbeddedResource Remove="WebServices\**\*.*" />
        <None Include="WebServices\**\*.cs" Exclude="WebServices\FuseCP.Build\obj\**\*.cs" />
        <None Remove="WebServices\FuseCP.Build\obj\**" />
        <None Remove="**\*.asmx" />
        <Content Remove="bin_dotnet\**\*.*" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
        <None Include="Default.aspx.designer.cs" />
        <None Include="Default.aspx.cs" />
        <Compile Remove="Default.aspx.designer.cs" />
        <Compile Remove="Default.aspx.cs" />
    </ItemGroup>
 
    <ItemGroup>
        <Content Remove="wwwroot\img\logo.png" />
        <None Include="wwwroot\img\logo.png">
          <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <!--<Content Include="wwwroot\img\logo.png" />-->
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\FuseCP.Build\FuseCP.Build.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="..\FuseCP.Providers.Database.SqlServer\FuseCP.Providers.Database.SqlServer.csproj" />
        <ProjectReference Include="..\FuseCP.Web.Services\FuseCP.Web.Services.csproj" />
        <ProjectReference Include="..\FuseCP.Providers.Base\FuseCP.Providers.Base.csproj" />
        <ProjectReference Include="..\FuseCP.Server.Utils\FuseCP.Server.Utils.csproj" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.4" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    </ItemGroup>
    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
        <PackageReference Include="CoreWCF.Primitives" Version="1.8.0" />
        <PackageReference Include="CoreWCF.WebHttp" Version="1.8.0" />
        <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.0" GeneratePathProperty="true" />
        <!--<PackageReference Include="System.Management" Version="8.0.0" GeneratePathProperty="true"
            IncludeAssets="None" ExcludeAssets="All" PrivateAssets="None" />-->
    </ItemGroup>
    <ItemGroup>
        <Compile Include="..\VersionInfo.cs" Link="VersionInfo.cs" />
    </ItemGroup>
    <ItemGroup>
        <Folder Include="WebServices\FuseCP.Build\FuseCP.Build.WebServices\" />
    </ItemGroup>
    
    <!--<Target Name="CopySystemManagement" AfterTargets="Build">
        <ItemGroup>
            <Dll Include="$(PkgSystem_Managemenet)\runtimes\win\lib\net10.0\System.Management.dll" />
        </ItemGroup>
        <Copy SourceFiles="@(Dll)" DestinationFolder="$(OutputDir)" />
    </Target>-->
    
    <Target Name="CopyServiceProcessRuntime" AfterTargets="Build" Condition="'$(TargetFramework)' == 'net10.0'">
        <Message Importance="high" Text="Copying $(PkgSystem_ServiceProcess_ServiceController)\runtimes\win\lib\net10.0\System.ServiceProcess.ServiceController.dll" />
        <Copy SourceFiles="$(PkgSystem_ServiceProcess_ServiceController)\runtimes\win\lib\net10.0\System.ServiceProcess.ServiceController.dll" DestinationFolder="$(OutputPath)" />
    </Target>

</Project>
