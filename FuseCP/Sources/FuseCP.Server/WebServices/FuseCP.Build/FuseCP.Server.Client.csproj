<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<LangVersion>11</LangVersion>
		<DefineConstants>$(DefineConstants);Client</DefineConstants>
		<ImplicitUsings>disable</ImplicitUsings>
		<OutputPath>..\..\..\..\Bin</OutputPath>
		<GenerateAssemblyInfo>False</GenerateAssemblyInfo>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
        <SignAssembly>true</SignAssembly>
		<AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)FuseCP.snk</AssemblyOriginatorKeyFile>
		<IntermediateOutputPath>$(BaseIntermediateOutputPath)$(Configuration)\$(TargetFramework.ToLowerInvariant())\</IntermediateOutputPath>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Microsoft.NET.Sdk.Razor.SourceGenerators\**" />
		<Compile Include="$(MSBuildThisFileDirectory)..\..\..\VersionInfo.cs" Link="VersionInfo.cs" />
        <EmbeddedResource Remove="Microsoft.NET.Sdk.Razor.SourceGenerators\**" />
		<None Remove="Microsoft.NET.Sdk.Razor.SourceGenerators\**" />
        <Services Include="FuseCP.Build.WebServices\**\*.g.cs" />
        <Folder Include="FuseCP.Build.WebServices" />
    </ItemGroup>
    <PropertyGroup>
        <AnyServices>@(Services)</AnyServices>
    </PropertyGroup>
	<ItemGroup>
		<ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\FuseCP.Web.Clients\FuseCP.Web.Clients.csproj" />
        <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\FuseCP.Server\FuseCP.Server.csproj" Condition="'$(AnyServices)' == ''"
			ReferenceOutputAssembly="false" PrivateAssets="All" />
    </ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="System.ServiceModel.Primitives" Version="10.0.652802" />
		<PackageReference Include="System.DirectoryServices" Version="10.0.0" />
		<PackageReference Include="CoreWCF.Primitives" Version="1.8.0"/>
	</ItemGroup>

    <Target Name="RerunAnalyzer" Condition="'$(AnyServices)' == ''" BeforeTargets="ResolveProjectReferences">
		<Touch Files="$(MSBuildThisFileDirectory)..\..\Properties\AssemblyInfo.cs" />
    </Target>
    
    <Target Name="ReevaluateCompile" Condition="'$(AnyServices)' == ''" AfterTargets="ResolveProjectReferences">
        <ItemGroup>
            <Compile Remove="**/*.cs" />
            <Compile Include="**/*.cs" Exclude="obj/**/*.cs" />
        </ItemGroup>
    </Target>

</Project>
