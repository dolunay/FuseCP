    <Message Text="@(IntermediateAssembly->'$(OutDir)%(FileName)%(Extension) to bin\%(FileName)%(Extension)')" />
    <ItemGroup>
      <FilesForPackagingFromProject Include="@(IntermediateAssembly->'$(OutDir)%(FileName)%(Extension)')">
