    <ItemGroup>
      <_WebConfigsToInsertEFCodeFirstDeployContext Include="@(FilesForPackagingFromProject)" Condition="'%(FilesForPackagingFromProject.Filename)%(FilesForPackagingFromProject.Extension)'=='$(ProjectConfigFileName)' &#xD;&#xA;                                         And !%(FilesForPackagingFromProject.Exclude)&#xD;&#xA;                                         And '%(DestinationRelativePath)' == '$(ProjectConfigFileName)'">
        <TransformOriginalFolder>$(InsertEFCodeFirstDeployWebCofigLocation)\original</TransformOriginalFolder>
