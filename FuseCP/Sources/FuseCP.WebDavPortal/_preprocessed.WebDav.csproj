    <!--Generate the command line script for the what-if msdeploy-->
    <MSdeploy PreviewCommandLineOnly="True" WhatIf="True" Verb="sync" Source="@(MsDeploySourceProviderSetting)" Destination="@(MsDeployDestinationProviderSetting)" DisableLink="$(PublishDisableLinks)" EnableLink="$(PublishEnableLinks)" SkipRuleItems="@(MsDeploySkipRules)" ImportSetParametersItems="%25_DeploySetParametersFile%25" ExePath="%25MSDeployPath%25">
