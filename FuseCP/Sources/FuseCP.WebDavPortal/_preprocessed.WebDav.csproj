    <MSdeploy PreviewCommandLineOnly="True" Verb="sync" Source="@(MsDeploySourceProviderSetting)" Destination="@(MsDeployDestinationProviderSetting)" DisableLink="$(PublishDisableLinks)" EnableLink="$(PublishEnableLinks)" SkipRuleItems="@(MsDeploySkipRules)" ImportSetParametersItems="%25_DeploySetParametersFile%25" ExePath="%25MSDeployPath%25">
      <Output TaskParameter="CommandLine" PropertyName="_SampleDeployScriptOnSetParametersFile" />
