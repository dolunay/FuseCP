  <Target Name="PipelineMsdeploySpecificTransformPhase" Outputs="@(FilesForPackagingFromProject)" DependsOnTargets="$(PipelineMsdeploySpecificTransformPhaseDependsOn)" BeforeTargets="$(PipelineMsdeploySpecificTransformPhaseBeforeTargets)" AfterTargets="$(PipelineMsdeploySpecificTransformPhaseAfterTargets)">
    <!--This is a phase separation point-->
    <!--This is a phase separation point. Some deploy doesn't need to copy all file to a folder, But for MSDeploy, it required to have all file in a single folder-->
    <GetPublishingLocalizedString ID="PublishLocalizedString_WebPublishPipelineDeployPhaseStage1" ArgumentCount="1" Arguments="PipelineMsdeploySpecificTransformPhase" LogType="Message" />
    <CallTarget Targets="$(OnAfterPipelineMsdeploySpecificTransformPhase)" RunEachTargetSeparately="False" />
